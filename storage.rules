rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check file size (in MB)
    function isValidSize(maxSizeMB) {
      return request.resource.size < maxSizeMB * 1024 * 1024;
    }
    
    // Helper function to check file type
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isPDF() {
      return request.resource.contentType == 'application/pdf';
    }
    
    function isDocument() {
      return request.resource.contentType.matches('application/(pdf|msword|vnd.openxmlformats-officedocument.wordprocessingml.document)');
    }
    
    // ===========================================================================
    // USER PROFILE PICTURES
    // ===========================================================================
    match /users/{userId}/profile/{fileName} {
      // Public read for profile pictures
      allow read: if true;
      
      // Users can upload their own profile picture
      // Max 5MB, must be image
      allow write: if isSignedIn() 
                   && request.auth.uid == userId 
                   && isImage() 
                   && isValidSize(5);
    }
    
    // ===========================================================================
    // MEMBER RESUMES
    // ===========================================================================
    match /users/{userId}/resumes/{fileName} {
      // Only the owner can read their resume (or admins via backend)
      // Employers get resume access through backend when member applies
      allow read: if isSignedIn() && request.auth.uid == userId;
      
      // Users can upload their own resume
      // Max 10MB, must be PDF or DOC
      allow write: if isSignedIn() 
                   && request.auth.uid == userId 
                   && isDocument() 
                   && isValidSize(10);
    }
    
    // ===========================================================================
    // EMPLOYER LOGOS
    // ===========================================================================
    match /employers/{employerId}/logo/{fileName} {
      // Public read for logos (displayed on job listings)
      allow read: if true;
      
      // Employers can upload their own logo
      // Max 2MB, must be image
      allow write: if isSignedIn() 
                   && request.auth.uid == employerId 
                   && isImage() 
                   && isValidSize(2);
    }
    
    // ===========================================================================
    // VENDOR/SHOP IMAGES
    // ===========================================================================
    match /vendors/{vendorId}/images/{fileName} {
      // Public read for shop images
      allow read: if true;

      // Vendors can upload shop images
      // Max 5MB per image, must be image
      allow write: if isSignedIn()
                   && request.auth.uid == vendorId
                   && isImage()
                   && isValidSize(5);
    }

    // ===========================================================================
    // VENDOR PRODUCT IMAGES
    // ===========================================================================
    match /vendors/{vendorId}/products/{fileName} {
      // Public read for product images
      allow read: if true;

      // Vendors can upload product images
      // Max 5MB per image, must be image
      allow write: if isSignedIn()
                   && request.auth.uid == vendorId
                   && isImage()
                   && isValidSize(5);
    }
    
    // ===========================================================================
    // CONFERENCE IMAGES
    // ===========================================================================
    match /conferences/{conferenceId}/images/{fileName} {
      // Public read
      allow read: if true;
      
      // Authenticated users can upload conference images
      // Max 5MB, must be image
      allow write: if isSignedIn() 
                   && isImage() 
                   && isValidSize(5);
    }
    
    // ===========================================================================
    // SCHOLARSHIP DOCUMENTS
    // ===========================================================================
    match /scholarships/{scholarshipId}/documents/{fileName} {
      // Public read for scholarship guidelines, etc.
      allow read: if true;
      
      // Authenticated users can upload scholarship documents
      // Max 10MB, PDF or images
      allow write: if isSignedIn() 
                   && (isDocument() || isImage()) 
                   && isValidSize(10);
    }
    
    // ===========================================================================
    // GENERAL UPLOADS (ADMIN ONLY)
    // ===========================================================================
    match /uploads/{allPaths=**} {
      // Public read for general uploads
      allow read: if true;
      
      // Only admins can upload to the general uploads folder
      // This requires backend verification
      allow write: if false; // Handled by backend with admin SDK
    }
  }
}
