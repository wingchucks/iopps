{
  "crons": [
    {
      "path": "/api/emails/send-job-alerts/daily",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/expire-jobs",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/sync-feeds?frequency=hourly",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-feeds?frequency=daily",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-feeds?frequency=weekly",
      "schedule": "0 7 * * 1"
    }
  ]
}
