rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to get user document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check if user is admin or moderator
    function isAdminOrModerator() {
      return isSignedIn() && getUserData().role in ['admin', 'moderator'];
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // ===========================================================================
    // USERS COLLECTION
    // ===========================================================================
    match /users/{userId} {
      // Anyone authenticated can read user profiles (for display names, etc.)
      allow read: if isSignedIn();
      
      // Users can only write to their own document
      // Admins can write to any user document
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdminOrModerator();
      allow delete: if isAdmin();
    }
    
    // ===========================================================================
    // EMPLOYER PROFILES
    // ===========================================================================
    match /employers/{employerId} {
      // Public read for employer profiles (displayed on job listings, etc.)
      allow read: if true;
      
      // Employers can create/update their own profile
      // Admins can modify any profile (for approval/rejection)
      allow create: if isOwner(employerId);
      allow update: if isOwner(employerId) || isAdminOrModerator();
      allow delete: if isAdmin();
    }
    
    // ===========================================================================
    // MEMBER PROFILES
    // ===========================================================================
    match /memberProfiles/{memberId} {
      // Members can read any profile (for networking, etc.)
      allow read: if isSignedIn();
      
      // Members can only create/update their own profile
      allow create: if isOwner(memberId);
      allow update: if isOwner(memberId);
      allow delete: if isOwner(memberId);
    }
    
    // ===========================================================================
    // JOB POSTINGS
    // ===========================================================================
    match /jobs/{jobId} {
      // Public read for all job postings
      allow read: if true;
      
      // Only authenticated employers can create jobs
      allow create: if isSignedIn() && request.resource.data.employerId == request.auth.uid;
      
      // Employers can update/delete their own jobs
      // Admins can modify any job
      allow update: if isOwner(resource.data.employerId) || isAdminOrModerator();
      allow delete: if isOwner(resource.data.employerId) || isAdminOrModerator();
    }
    
    // ===========================================================================
    // JOB APPLICATIONS
    // ===========================================================================
    match /applications/{applicationId} {
      // Applicants can read their own applications
      // Employers can read applications to their jobs
      // Admins can read all
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.memberId ||
        request.auth.uid == resource.data.employerId ||
        isAdminOrModerator()
      );
      
      // Only authenticated members can create applications
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      
      // Applicants can update their own applications (withdraw)
      // Employers can update status
      // Admins can update any
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.memberId ||
        request.auth.uid == resource.data.employerId ||
        isAdminOrModerator()
      );
      
      // Only admins can delete
      allow delete: if isAdmin();
    }
    
    // ===========================================================================
    // SAVED JOBS
    // ===========================================================================
    match /savedJobs/{savedJobId} {
      // Users can only read/write their own saved jobs
      allow read: if isSignedIn() && resource.data.memberId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.memberId == request.auth.uid;
    }
    
    // ===========================================================================
    // CONFERENCES
    // ===========================================================================
    match /conferences/{conferenceId} {
      // Public read for all conferences
      allow read: if true;
      
      // Employers can create conferences
      allow create: if isSignedIn() && request.resource.data.employerId == request.auth.uid;
      
      // Employers can update/delete their own conferences
      // Admins can modify any
      allow update: if isOwner(resource.data.employerId) || isAdminOrModerator();
      allow delete: if isOwner(resource.data.employerId) || isAdminOrModerator();
    }
    
    // ===========================================================================
    // SCHOLARSHIPS
    // ===========================================================================
    match /scholarships/{scholarshipId} {
      // Public read
      allow read: if true;
      
      // Employers can create scholarships
      allow create: if isSignedIn() && request.resource.data.employerId == request.auth.uid;
      
      // Employers can update/delete their own
      // Admins can modify any
      allow update: if isOwner(resource.data.employerId) || isAdminOrModerator();
      allow delete: if isOwner(resource.data.employerId) || isAdminOrModerator();
    }
    
    // ===========================================================================
    // SCHOLARSHIP APPLICATIONS
    // ===========================================================================
    match /scholarshipApplications/{applicationId} {
      // Similar to job applications
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.memberId ||
        request.auth.uid == resource.data.employerId ||
        isAdminOrModerator()
      );
      
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.memberId ||
        request.auth.uid == resource.data.employerId ||
        isAdminOrModerator()
      );
      
      allow delete: if isAdmin();
    }
    
    // ===========================================================================
    // POW WOWS
    // ===========================================================================
    match /powwows/{powwowId} {
      // Public read
      allow read: if true;
      
      // Admins and employers can create
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.employerId) || isAdminOrModerator();
      allow delete: if isAdminOrModerator();
    }
    
    // ===========================================================================
    // SHOP LISTINGS (Indigenous Businesses)
    // ===========================================================================
    match /shopListings/{listingId} {
      // Public read
      allow read: if true;
      
      // Vendors can create listings
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.employerId) || isAdminOrModerator();
      allow delete: if isAdminOrModerator();
    }
    
    // ===========================================================================
    // VENDOR PROFILES
    // ===========================================================================
    match /vendors/{vendorId} {
      // Public read
      allow read: if true;
      
      // Vendors can create/update their own profile
      allow create: if isOwner(vendorId);
      allow update: if isOwner(vendorId) || isAdminOrModerator();
      allow delete: if isAdmin();
    }
    
    // ===========================================================================
    // LIVE STREAMS
    // ===========================================================================
    match /liveStreams/{streamId} {
      // Public read
      allow read: if true;
      
      // Admins and employers can manage
      allow create: if isSignedIn();
      allow update: if isOwner(resource.data.employerId) || isAdminOrModerator();
      allow delete: if isAdminOrModerator();
    }
    
    // ===========================================================================
    // CONTACT SUBMISSIONS
    // ===========================================================================
    match /contactSubmissions/{submissionId} {
      // Anyone can create (submit contact form)
      allow create: if true;
      
      // Only admins/moderators can read and update
      allow read: if isAdminOrModerator();
      allow update: if isAdminOrModerator();
      allow delete: if isAdmin();
    }
    
    // ===========================================================================
    // PLATFORM SETTINGS (Admin Only)
    // ===========================================================================
    match /settings/{document=**} {
      // Anyone authenticated can read settings (for announcement banner, etc.)
      allow read: if isSignedIn();
      
      // Only admins can write
      allow write: if isAdmin();
    }
    
    // ===========================================================================
    // RSS FEEDS (Admin Only)
    // ===========================================================================
    match /rssFeeds/{feedId} {
      // Admins and moderators can manage RSS feeds
      allow read: if isAdminOrModerator();
      allow write: if isAdminOrModerator();
    }
  }
}
